# Streamlit Cloud Secrets template (safe to commit — store HASHes only, not plain keys)
#
# Generate hashes locally:
#   python scripts/hash_secret.py "your-site-password"
#   python scripts/hash_secret.py "your-write-key"
#
# Optional extra pepper (use the same value when hashing and in Secrets):
# SECRET_HASH_SALT = "optional-random-string"

SITE_PASSWORD_HASH = "paste-sha256-hex-from-hash_secret.py"
WRITE_API_KEY_HASH = "paste-sha256-hex-from-hash_secret.py"
PUBLIC_BASE_URL = "https://your-app-name.streamlit.app"
